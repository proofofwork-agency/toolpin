{
  "name": "toolpin",
  "version": "0.1.0",
  "description": "Trusted install, lockfile, and governance layer for MCP servers",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lockfile",
    "supply-chain",
    "cli",
    "github-action"
  ],
  "homepage": "https://github.com/proofofworks/TPN#readme",
  "bugs": {
    "url": "https://github.com/proofofworks/TPN/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proofofworks/TPN.git"
  },
  "type": "module",
  "packageManager": "npm@10.9.2",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "action.yml",
    "registry",
    "docs/how-to/catch-drift-in-ci.md",
    "docs/how-to/custom-registries.md",
    "docs/how-to/toolpin-curated-registry.md"
  ],
  "bin": {
    "toolpin": "./dist/cli.js",
    "tpn": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "docs:build": "docusaurus build website",
    "docs:clear": "docusaurus clear website",
    "docs:start": "docusaurus start website",
    "registry:check": "node scripts/check-curated-registry.mjs",
    "test": "npm run build && node --test",
    "release:check": "npm test && npm run registry:check && node scripts/check-publish-target.mjs && npm pack --dry-run",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "start": "node dist/cli.js",
    "dev": "npm run build && node dist/cli.js",
    "tui": "npm run build && node dist/cli.js tui",
    "smoke": "npm run build && node dist/cli.js search github --limit 3 --live"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.17",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  }
}
